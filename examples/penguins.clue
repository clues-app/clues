        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "binSize": "",
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(235, 237, 239)\"><span style=\"font-size: 28px\">We saw already some marginal box plots as in our Bill Length vs Flipper Length by species, but here is a full graph on the penguin's body mass.<br></span><br>As we already saw, Gentoo penguins are the heaviest.<br><br>By splitting the graph by island, we can see that Adelie penguins have the same distribution of weight along the 3 islands ...</span>",
      "presoNoteSize": 28,
      "splitBy": "species",
      "height": 901,
      "presoNoteWidth": 548,
      "panelWidth": 922,
      "panelLeft": 661,
      "presoNoteLeft": 90,
      "presoNotePos": "left"
    },
    {
      "id": "epz0f3xff",
      "type": "box",
      "key": "bill_length_mm",
      "groupBy": "island",
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "binSize": "",
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(235, 237, 239)\">... But that's not the case for the bill length, which seems to have less dispersion in Biscoe.</span>",
      "presoNoteSize": 28,
      "splitBy": "species",
      "height": 901,
      "presoNoteWidth": 511,
      "panelWidth": 910,
      "panelLeft": 90,
      "presoNoteLeft": 1086,
      "presoNotePos": "right",
      "legendPosition": "custom",
      "legendCustom": {
