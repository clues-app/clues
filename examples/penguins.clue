        "y": 0.908,
        "xanchor": "center",
        "yanchor": "top",
        "orientation": "h"
      }
    },
    {
      "id": "ppecdf",
      "type": "ecdf",
      "key": "flipper_length_mm",
      "groupBy": "species",
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "binSize": "",
      "showPresoNote": true,
      "presoNote": "And maybe the less common&nbsp;Empirical Cumulative Distribution Function.",
      "presoNoteSize": 28,
      "presoNoteColor": "#f7f7f8",
      "presoNotePos": "left",
      "presoNoteWidth": 548,
      "panelWidth": 921,
      "panelLeft": 661,
