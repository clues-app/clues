      },
      "binSize": "",
      "showPresoNote": true,
      "presoNote": "<span style=\"font-size: 28px; color: rgb(234, 237, 241)\">And here's a more traditional way to represent the distribution of weight among these birds: a traditional histogram</span>",
      "presoNoteSize": 28,
      "height": 901,
      "facetBy": "sex",
