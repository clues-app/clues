  "presentMode": true,
  "showTrendlines": true,
  "showTrendFormula": false,
  "relCharts": [
    {
      "id": "ppsplom",
      "type": "matrix",
      "groupBy": "overall",
      "x": "bill_length_mm",
      "y": "bill_depth_mm",
      "size": "",
      "styleBy": "",
      "dimensions": [
        "bill_length_mm",
        "bill_depth_mm",
        "flipper_length_mm",
        "body_mass_g"
      ],
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "showLegend": false,
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(235, 237, 239)\">Let's start our journey by showing a scatter matrix between all the measurements taken during the research.<br><br>We can already see visually that there are some positive trend. For some others, we can't really say anything.<br><br>Let's add some color to this ...<br><br></span>",
      "presoNoteSize": 28,
      "presoNoteWidth": 559,
      "panelWidth": 921,
      "height": 906,
      "panelLeft": 661,
      "presoNoteLeft": 79
    },
    {
      "id": "4sxrgwkh2",
      "type": "matrix",
      "groupBy": "species",
      "x": "bill_length_mm",
      "y": "body_mass_g",
      "size": "",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.603,
        "y": 0.519,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "panelWidth": 910,
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(235, 237, 239); font-size: 28px\">Here is the same scatter matrix, but now each point has a color per species.<br>And we can see that the linear relation is even more evident for some of these pairs of measures...<br><br>Let's take a look at some of these pairs ...</span>",
      "presoNoteWidth": 511,
      "presoNotePos": "right",
      "height": 906,
      "panelLeft": 90,
      "presoNoteLeft": 1086
    },
    {
      "id": "dwiz6585m",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "body_mass_g",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.184,
        "y": 0.957,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "marginals": false,
      "panelWidth": 955,
      "presentHide": true,
      "jitter": true
    },
    {
      "id": "41zsog56y",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": true,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "marginals": true,
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.026,
        "y": 0.85,
        "xanchor": "left",
        "yanchor": "top",
        "orientation": "v"
      },
      "panelWidth": 921,
      "showPresoNote": true,
      "presoNotePos": "left",
      "presoNote": "<span style=\"font-size: 28px; color: rgb(240, 242, 245)\">In this graph, we have on the horizontal axis the flipper length, and the bill length of the vertical axis...<br><br>And again, the color differentiation by species</span>",
      "presoNoteWidth": 559,
      "jitter": true,
      "height": 906,
      "panelLeft": 661,
      "presoNoteLeft": 79
    },
    {
      "id": "lg11e7xrr",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "body_mass_g",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "styleLegendCustom": {
        "x": 0.054,
        "y": 1,
        "xanchor": "left",
        "yanchor": "top",
        "orientation": "v"
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.167,
        "y": 0.931,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "showStyleLegend": true,
      "showPresoNote": true,
      "presoNoteWidth": 511,
      "presoNote": "<span style=\"font-size: 28px; color: rgb(240, 242, 245)\">Still the same pair Bill vs Flipper lengths, but this time we also add the Body Mass(g) on a point: the heavier the bird, the larger the point...<br><br>And we can see that shorter bills and flippers, in general, means lighter birds or conversely. Not surprising, because naturally one can expect that chicks have lower measures of all three measurement.<br><br>We don't have the age of the birds in our dataset but we can add one more thing...</span>",
      "panelWidth": 910,
      "height": 906,
      "presoNotePos": "right",
      "panelLeft": 90,
      "presoNoteLeft": 1086,
      "jitter": true
    },
    {
      "id": "076wn8q12",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "body_mass_g",
      "styleBy": "sex",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "styleLegendCustom": {
        "x": 0.054,
        "y": 0.847,
        "xanchor": "left",
        "yanchor": "top",
        "orientation": "v"
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.943,
        "y": 0.407,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "showStyleLegend": true,
      "showPresoNote": true,
      "presoNoteWidth": 559,
      "presoNote": "<span style=\"color: rgb(240, 242, 245); font-size: 28px\">Still the same pair Bill vs Flipper lengths, with the Body Mass(g) and the sex of a penguin...</span><br style=\" color: rgb(240, 242, 245); font-size: 28px\"><br style=\" color: rgb(240, 242, 245); font-size: 28px\"><span style=\"color: rgb(240, 242, 245); font-size: 28px\">This is a \"Style\" marker showing for missing data a thick border, for females a thin border, no filling color, and for males no border but filling color...<br><br>Ballpark we can see that males are in general heavier and have longer bills and flippers.<br><br>Since this is an interactive chart, we can hover over points or mute a specific legend item</span>",
      "height": 906,
      "presoNotePos": "left",
      "panelWidth": 922,
      "panelLeft": 661,
      "presoNoteLeft": 79
    },
    {
      "id": "4iwb6yzwm",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "body_mass_g",
      "styleBy": "sex",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "styleLegendCustom": {
        "x": 0.054,
        "y": 1,
        "xanchor": "left",
        "yanchor": "top",
        "orientation": "v"
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.943,
        "y": 0.407,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "showStyleLegend": true,
      "showPresoNote": true,
      "presoNoteWidth": 511,
      "presoNote": "<span style=\"color: rgb(240, 242, 245); font-size: 28px\">But for each pair of measurement, we also have yet another categorical field value: the island were the measurement was collected.<br><br>Now we could filter our dataset and look at each island separately...But the filters affect all graphs simultaneously.<br><br>A simpler way could be to break the previous graph into facets, each of them being a different island.</span>",
      "height": 906,
      "presoNotePos": "right",
      "panelWidth": 910,
      "facetBy": "island",
      "marginals": false,
      "panelLeft": 90,
      "presoNoteLeft": 1086
    },
    {
      "id": "0vdxes29m",
      "type": "scatter",
      "groupBy": "species",
      "x": "flipper_length_mm",
      "y": "bill_length_mm",
      "size": "body_mass_g",
      "styleBy": "island",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "styleLegendCustom": {
        "x": 0.054,
        "y": 0.926,
        "xanchor": "left",
        "yanchor": "top",
        "orientation": "v"
      },
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.943,
        "y": 0.407,
        "xanchor": "right",
        "yanchor": "top",
        "orientation": "v"
      },
      "showStyleLegend": true,
      "showPresoNote": true,
      "presoNoteWidth": 559,
      "presoNote": "<span style=\"color: rgb(240, 242, 245); font-size: 28px\">An alternative solution would be to use the \"Styling\" to represent the island ...<br><br>So here thick border means Biscoe, thin-no filling means Dream, and filling no border means Torgersen.<br><br>Somehow for me, this isn't very easy to read, but I wanted to let you know that it is a possibility.</span>",
      "height": 906,
      "presoNotePos": "left",
      "panelWidth": 922,
      "panelLeft": 661,
      "presoNoteLeft": 79
    },
    {
      "id": "lxutf9m5p",
      "type": "parcoords",
      "groupBy": "species",
      "x": "bill_length_mm",
      "y": "bill_depth_mm",
      "size": "",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "showLegend": true,
      "panelWidth": 910,
      "showPresoNote": true,
      "presoNote": "<span style=\"font-size: 28px; color: rgb(241, 242, 243)\">Another graph showing the relationship between fields is the parallel chart...<br><br>Scrolling down form the body mass from the top right bar, we can see that we almost have the entire population of Gentoo, before Chinstrap and Adelie start to appear...</span>",
      "presoNotePos": "right",
      "height": 901,
      "panelLeft": 90,
      "presoNoteWidth": 511,
      "presoNoteLeft": 1086
    },
    {
      "id": "4p9gp4448",
      "type": "scatter3d",
      "groupBy": "species",
      "x": "bill_length_mm",
      "y": "bill_depth_mm",
      "size": "",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "spin3d": false,
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(241, 242, 243); font-size: 28px\">We can also show 3 numerical values on a 3D scatter plot. Not very useful here, besides the fact that clearly, from the standpoint of t 3 measures - bill length, bill depth and body mass - Gentoo penguins are different.</span>",
      "presoNotePos": "left",
      "panelWidth": 921,
      "jitter": false,
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.479,
        "y": 0.977,
        "xanchor": "center",
        "yanchor": "top",
        "orientation": "h"
      },
      "height": 901,
      "presoNoteWidth": 559,
      "panelLeft": 661,
      "presoNoteLeft": 79,
      "z": "body_mass_g"
    },
    {
      "id": "5181y2qq1",
      "type": "scatter3d",
      "groupBy": "species",
      "x": "bill_length_mm",
      "y": "bill_depth_mm",
      "size": "",
      "styleBy": "",
      "showTrendline": true,
      "showTrendFormula": false,
      "axes": {
        "x": {
          "min": "",
          "max": ""
        },
        "y": {
          "min": "",
          "max": ""
        }
      },
      "spin3d": true,
      "showPresoNote": true,
      "presoNote": "<span style=\"color: rgb(241, 242, 243); font-size: 28px\">We can take different combinations,&nbsp; like 2 numerical fields + 1 categorical field.<br><br></span><div><span style=\"color: rgb(241, 242, 243); font-size: 28px\">Here the scatter plot of bill length vs bill depth and the island in the Z axis...<br><br>Again, you can see that Adelie penguins are in the 3 islands.</span></div>",
      "presoNotePos": "right",
      "panelWidth": 910,
      "jitter": false,
      "legendPosition": "custom",
      "legendCustom": {
        "x": 0.901,
        "y": 0.885,
